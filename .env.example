# =====================================================================
# ローカル開発用 環境変数サンプル
# このファイルをコピーして .env を作成し、実際の値を記入してください。
# =====================================================================

# ----- Slack ----------------------------------------------------------
# Slack App 管理画面(api.slack.com/apps) > OAuth & Permissions > Bot User OAuth Token
SLACK_BOT_TOKEN=xoxb-your-bot-token-here

# Slack App 管理画面(api.slack.com/apps) > Basic Information > App-Level Tokens (Socket Mode 用)
SLACK_APP_TOKEN=xapp-your-app-token-here

# ----- New Relic ------------------------------------------------------
# NR UI > 右上アバター > API keys > Create key (type: User)
# monitoring/ の Terraform コマンド（make monitoring-*）にも自動的に使用される
NEW_RELIC_API_KEY=NRAK-your-api-key-here

# NR UI > 右上アバター > API keys > Account ID
# monitoring/ の Terraform コマンド（make monitoring-*）にも自動的に使用される
NEW_RELIC_ACCOUNT_ID=your-account-id-here

# NR UI > 右上アバター > API keys > Create key (type: INGEST - LICENSE)
# 未設定の場合、APM エージェントは無効モードで起動する（ボット動作には影響なし）
NEW_RELIC_LICENSE_KEY=your-ingest-license-key-here

# NR アプリケーション名（APM で表示される名前）
NEW_RELIC_APP_NAME=newrelic-slack-bot

# ----- AWS -----------------------------------------------------------
# CDK デプロイ先リージョン兼 Bedrock API エンドポイント。
AWS_DEFAULT_REGION=ap-northeast-1

# Bedrock モデル / 推論プロファイル ID
# ap-northeast-1 (東京) はリージョン内推論が非対応のため Japan Geo 推論プロファイル (jp.*) を使用する。
# 東京・大阪間でルーティングされ、データは日本国内に留まる。
# 使用するモデルに合わせて一方をコメントアウトしてください。
BEDROCK_MODEL_ID=jp.anthropic.claude-sonnet-4-6
# BEDROCK_MODEL_ID=jp.anthropic.claude-sonnet-4-5-20250929-v1:0

# ローカルで aws configure が未設定の場合のみ以下を設定してください。
# (ECS 上では IAM タスクロールが使われるため不要)
# AWS_ACCESS_KEY_ID=your-access-key-id
# AWS_SECRET_ACCESS_KEY=your-secret-access-key
